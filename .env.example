# Cloudflare Web Analytics beacon token (public — ships in client HTML, safe to expose).
# Get it from: Cloudflare Dashboard → Web Analytics → Add site (jasonwpalmer.com) → copy the token.
# Leave blank or unset to disable analytics entirely (beacon script is not injected).
NEXT_PUBLIC_CF_BEACON_TOKEN=

# ---------------------------------------------------------------------------
# Dispatch mailing list (Resend + Cloudflare D1)
# ---------------------------------------------------------------------------

# Resend API key — required for sending confirmation and dispatch emails.
# Get it from: https://resend.com/api-keys
# KEEP THIS SECRET — never commit, never expose in client code or logs.
# For production: set via `npx wrangler pages secret put RESEND_API_KEY --project-name jasonwpalmer-com`
RESEND_API_KEY=

# Public URL of the site (no trailing slash). Used for confirmation/unsubscribe links.
SITE_URL=https://jasonwpalmer.com

# The "from" address used for all outbound emails.
# Must be on a domain verified in your Resend account (dispatch@jasonwpalmer.com
# requires jasonwpalmer.com to be added + DNS-verified in Resend).
FROM_EMAIL="Jason Palmer <dispatch@jasonwpalmer.com>"
